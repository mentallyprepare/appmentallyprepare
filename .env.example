# ─── Server ────────────────────────────────
PORT=3005
NODE_ENV=development
BASE_URL=http://localhost:3005
SESSION_SECRET=change-me-to-a-long-random-string
DB_PATH=mentally-prepare.db
TRUST_PROXY=1                    # Number of proxy hops (set in production)
CORS_ORIGINS=http://localhost:3005,https://yourdomain.com

# ─── Admin ──────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-admin-password

# ─── LLM (at least one required for AI features) ───
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Email ─────────────────────────────────
# Option A: SMTP (works with SendGrid, Gmail, etc.)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.xxxxx
# EMAIL_FROM=MentallyPrepare <noreply@yourdomain.com>

# Option B: Resend API (simpler, no SMTP config)
# RESEND_API_KEY=re_...

# Leave both unset to use Ethereal (dev-only, previews at ethereal.email)

# ─── Payments ──────────────────────────────
RAZORPAY_KEY_ID=rzp_...
RAZORPAY_KEY_SECRET=...
STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...           # Only needed for processing Stripe webhooks

# ─── Push ──────────────────────────────────
# VAPID keys auto-generated on first run to .vapid-keys.json
CONTACT_EMAIL=hello@mentallyprepare.in
